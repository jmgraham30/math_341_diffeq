    "#| label: fig-sho-slides\n",
    "#| fig-cap: 'Left: position $x(t)$. Right: phase portrait — each closed ellipse is a periodic solution.'\n",
    "\n",
    "omega = 1.0\n",
    "t_span = (0, 4*np.pi)\n",
    "t_eval = np.linspace(*t_span, 500)\n",
    "\n",
    "def sho(t, y):\n",
    "    return [y[1], -omega**2 * y[0]]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(9, 3.5))\n",
    "\n",
    "sol = solve_ivp(sho, t_span, [1.0, 0.0], t_eval=t_eval)\n",
    "axes[0].plot(sol.t, sol.y[0], color='steelblue', lw=2)\n",
    "axes[0].set_xlabel('$t$'); axes[0].set_ylabel('$x(t)$')\n",
    "axes[0].set_title('Position vs. Time'); axes[0].axhline(0, color='k', lw=0.5)\n",
    "\n",
    "x_v = np.linspace(-2.5, 2.5, 300); v_v = np.linspace(-2.5, 2.5, 300)\n",
    "X, V = np.meshgrid(x_v, v_v)\n",
    "speed = np.sqrt(V**2 + (omega**2*X)**2); speed[speed==0] = 1\n",
    "axes[1].streamplot(x_v, v_v, V/speed, -omega**2*X/speed,\n",
    "                   color=np.log1p(speed), cmap='Blues', linewidth=0.7, density=1.3)\n",
    "for ic, lw, col in [((1.0,0.0), 2.5, 'crimson'), ((1.8,0.0), 1.2, 'steelblue'), ((0.6,0.0), 1.2, 'steelblue')]:\n",
    "    s = solve_ivp(sho, (0,2*np.pi), list(ic), t_eval=np.linspace(0,2*np.pi,300))\n",
    "    axes[1].plot(s.y[0], s.y[1], color=col, lw=lw)\n",
    "axes[1].set_xlabel('$x$'); axes[1].set_ylabel(r'$\\dot{x}$')\n",
    "axes[1].set_title('Phase Portrait'); axes[1].set_aspect('equal')\n",
    "\n",
    "plt.suptitle(r'SHO: $\\ddot{x}+\\omega^2 x=0$, $\\omega=1$', fontsize=11)\n",
